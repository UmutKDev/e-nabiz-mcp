# E-Nabız kimlik bilgileri — bu dosyayı `.env` olarak kopyalayıp doldurun.
# `.env` .gitignore'da; ASLA commit etmeyin.

# T.C. Kimlik Numarası (11 hane)
ENABIZ_TCKIMLIK=

# E-Nabız şifresi
ENABIZ_SIFRE=

# (opsiyonel) Oturum önbellek dosyası yolu.
# Varsayılan: ~/.config/enabiz-mcp/session.json
# ENABIZ_SESSION_PATH=

# (opsiyonel) İstekler arası minimum bekleme (saniye). WAF'ı tetiklememek için.
# Varsayılan: 0.5
# ENABIZ_MIN_INTERVAL=0.5

# (opsiyonel) İndirilen PDF'lerin (rapor/epikriz/patoloji) kaydedileceği dizin.
# Varsayılan: ~/.config/enabiz-mcp/downloads
# ENABIZ_DOWNLOAD_DIR=
